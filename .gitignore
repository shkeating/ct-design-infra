# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Package dist output specifically — the generic `dist/` rule above only stops *new*
# files here from being tracked; these were committed before that rule was in place,
# so `git rm --cached` was run once to untrack them too. Regenerated by
# `pnpm build:tokens`/`build:core`; never commit them.
packages/tokens/dist/
packages/core/dist/

# Generated component manifest (scripts/build-registry.mjs), derived from dist/custom-elements.json
# during `pnpm build:core` — regenerate it, never hand-edit or commit it.
packages/core/registry.json

# Generated barrel file (scripts/build-index.mjs), derived from every component file under
# src/components/. Regenerated by `pnpm build`/`pnpm dev`/`pnpm scaffold` — never hand-edit or
# commit it. Kept out of git specifically so parallel component-porting branches never collide
# on it (see docs/parallel-porting.md).
packages/core/src/index.ts

# Environment and Logs
.env
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS specific files
.DS_Store
Thumbs.db

# Fractal build output
packages/core/build/

# scripts/verify-component.mjs screenshot output
packages/core/.verify/

# .claude/skills/sonnet-a11y-audit scratch output (axe + screenshot evidence, EARL reports)
packages/core/.a11y-audit/

# Playwright run output
playwright-report/
test-results/

# Local-only Playwright visual-regression baselines. CI only ever runs on Linux and
# compares against *-chromium-linux.png; a local `--update-snapshots` run on macOS/Windows
# produces *-darwin.png/*-win32.png files that CI never reads and that should never be
# committed — only baselines generated via ci.yml's workflow_dispatch update_snapshots run
# are real (see docs/adr/0007-playwright-for-visual-regression.md and the add-component skill).
*-chromium-darwin.png
*-chromium-win32.png
