{
  "name": "@ct-infra/core",
  "version": "0.1.0",
  "description": "Base Lit implementation for Civic-Theme infrastructure",
  "type": "module",
  "main": "./dist/ct-core.umd.cjs",
  "module": "./dist/ct-core.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ct-core.js",
      "require": "./dist/ct-core.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "fractal:start": "node lab.cjs",
    "fractal:build": "fractal build --config fractal.config.cjs"
  },
  "dependencies": {
    "@ct-infra/tokens": "workspace:*",
    "lit": "^3.1.2"
  },
  "devDependencies": {
    "@frctl/fractal": "^1.5.15",
    "@frctl/handlebars": "^1.2.15",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
