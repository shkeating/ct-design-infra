{
  "name": "@ct-infra/core",
  "version": "0.1.0",
  "description": "Base Lit implementation for Civic-Theme infrastructure",
  "type": "module",
  "main": "./dist/ct-core.umd.cjs",
  "module": "./dist/ct-core.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ct-core.js",
      "require": "./dist/ct-core.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp ../tokens/dist/variables.css ./dist/variables.css",
    "fractal:start": "node lab.cjs",
    "fractal:build": "fractal build --config fractal.config.cjs",
    "test": "web-test-runner --node-resolve",
    "scaffold": "node scripts/scaffold.js"
  },
  "dependencies": {
    "@ct-infra/tokens": "workspace:*",
    "lit": "^3.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@frctl/fractal": "^1.5.15",
    "@frctl/handlebars": "^1.2.15",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
