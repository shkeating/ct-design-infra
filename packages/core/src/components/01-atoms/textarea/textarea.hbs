<ct-textarea
  theme="{{theme}}"
  name="{{name}}"
  {{#if id}}id="{{id}}"{{/if}}
  {{#if value}}value="{{value}}"{{/if}}
  {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
  {{#if rows}}rows="{{rows}}"{{/if}}
  {{#if isInvalid}}is-invalid{{/if}}
  {{#if isDisabled}}is-disabled{{/if}}
  {{#if isRequired}}is-required{{/if}}
  {{#if ariaLabel}}aria-label="{{ariaLabel}}"{{/if}}
  {{#if modifierClass}}modifier-class="{{modifierClass}}"{{/if}}
></ct-textarea>
