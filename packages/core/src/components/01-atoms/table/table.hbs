<ct-table
  theme="{{theme}}"
  {{#if caption}}caption="{{caption}}"{{/if}}
  {{#if captionPosition}}caption-position="{{captionPosition}}"{{/if}}
  {{#if header}}header="{{header}}"{{/if}}
  {{#if rows}}rows="{{rows}}"{{/if}}
  {{#if footer}}footer="{{footer}}"{{/if}}
  {{#if striped}}striped{{/if}}
  {{#if dataTable}}data-table{{/if}}
  {{#if modifierClass}}modifier-class="{{modifierClass}}"{{/if}}
></ct-table>
