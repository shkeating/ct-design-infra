<ct-video
  theme="{{theme}}"
  {{#if videoTitle}}title="{{videoTitle}}"{{/if}}
  {{#if hasControls}}has-controls{{/if}}
  src="{{src}}"
  {{#if type}}type="{{type}}"{{/if}}
  {{#if poster}}poster="{{poster}}"{{/if}}
  {{#if width}}width="{{width}}"{{/if}}
  {{#if height}}height="{{height}}"{{/if}}
  {{#if fallbackText}}fallback-text="{{fallbackText}}"{{/if}}
  {{#if modifierClass}}modifier-class="{{modifierClass}}"{{/if}}
></ct-video>
