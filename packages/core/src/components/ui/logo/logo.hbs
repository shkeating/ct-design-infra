<ct-logo
  theme="{{theme}}"
  type="{{type}}"
  primary-mobile-url="{{primaryMobileUrl}}"
  primary-mobile-alt="{{primaryMobileAlt}}"
  primary-desktop-url="{{primaryDesktopUrl}}"
  primary-desktop-alt="{{primaryDesktopAlt}}"
  {{#if secondaryMobileUrl}}secondary-mobile-url="{{secondaryMobileUrl}}"{{/if}}
  {{#if secondaryMobileAlt}}secondary-mobile-alt="{{secondaryMobileAlt}}"{{/if}}
  {{#if secondaryDesktopUrl}}secondary-desktop-url="{{secondaryDesktopUrl}}"{{/if}}
  {{#if secondaryDesktopAlt}}secondary-desktop-alt="{{secondaryDesktopAlt}}"{{/if}}
  {{#if url}}url="{{url}}"{{/if}}
  {{#if title}}title="{{title}}"{{/if}}
  {{#if modifierClass}}modifier-class="{{modifierClass}}"{{/if}}
></ct-logo>
