<ct-link
  theme="{{theme}}"
  label="{{label}}"
  icon-placement="{{iconPlacement}}"
  {{#if url}}url="{{url}}"{{/if}}
  {{#if linkTitle}}title="{{linkTitle}}"{{/if}}
  {{#if icon}}icon="{{icon}}"{{/if}}
  {{#if disabled}}disabled{{/if}}
  {{#if active}}active{{/if}}
  {{#if newWindow}}new-window{{/if}}
  {{#if external}}external{{/if}}
  {{#if iconGroupDisabled}}icon-group-disabled{{/if}}
  {{#if iconSingleOnly}}icon-single-only{{/if}}
  {{#if modifierClass}}modifier-class="{{modifierClass}}"{{/if}}
></ct-link>
