      "hover-border-color": { "$value": "{color.dark.interaction.hover-background}", "$type": "color", "description": "CivicTheme --ct-textfield-dark-hover-border-color." },
      "hover-color": { "$value": "{color.dark.body}", "$type": "color", "description": "CivicTheme --ct-textfield-dark-hover-color." },
      "focus-background-color": { "$value": "{color.dark.background}", "$type": "color", "description": "CivicTheme --ct-textfield-dark-focus-background-color." },
