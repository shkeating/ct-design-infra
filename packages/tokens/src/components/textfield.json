    "outline-offset": { "$value": "2px", "$type": "dimension", "description": "CivicTheme --ct-textfield-outline-offset." },
    "disabled-opacity": { "$value": "40%", "$type": "opacity", "description": "CivicTheme --ct-textfield-disabled-opacity." },
    "light": {
      "background-color": { "$value": "{color.light.background-light}", "$type": "color", "description": "CivicTheme --ct-textfield-light-background-color." },
