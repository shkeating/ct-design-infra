      "invalid-border-color": { "$value": "{color.light.error}", "$type": "color", "description": "CivicTheme --ct-textfield-light-invalid-border-color." },
      "invalid-color": { "$value": "{color.light.body}", "$type": "color", "description": "CivicTheme --ct-textfield-light-invalid-color." },
