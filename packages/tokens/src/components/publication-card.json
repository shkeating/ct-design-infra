{
  "publication-card": {
    "border-radius": { "$value": "0.25rem", "$type": "dimension", "description": "CivicTheme --ct-publication-card-border-radius." },
    "image-height-mobile": { "$value": "11.5rem", "$type": "dimension", "description": "CivicTheme --ct-publication-card-image-height-mobile." },
    "image-width-mobile": { "$value": "auto", "$type": "string", "description": "CivicTheme --ct-publication-card-image-width-mobile." },
    "image-height-desktop": { "$value": "11.5rem", "$type": "dimension", "description": "CivicTheme --ct-publication-card-image-height-desktop (>=768px)." },
    "image-width-desktop": { "$value": "50%", "$type": "string", "description": "CivicTheme --ct-publication-card-image-width-desktop (>=768px)." },
    "light": {
      "background-color": { "$value": "{color.light.background-light}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-background-color: var(--ct-color-light-background-light)." },
      "hover-outline-color": { "$value": "{color.light.border}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-hover-outline-color: var(--ct-color-light-border)." },
      "title-color": { "$value": "{color.light.heading}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-title-color: var(--ct-color-light-heading)." },
      "title-hover-color": { "$value": "{color.light.interaction.background}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-title-hover-color: var(--ct-color-light-interaction-background)." },
      "title-icon-color": { "$value": "{color.light.heading}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-title-icon-color: var(--ct-color-light-heading)." },
      "filename-color": { "$value": "{color.light.interaction.background}", "$type": "color", "description": "CivicTheme --ct-publication-card-light-filename-color: var(--ct-color-light-interaction-background)." }
    },
    "dark": {
      "background-color": { "$value": "{color.dark.background}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-background-color: var(--ct-color-dark-background)." },
      "hover-outline-color": { "$value": "{color.dark.border}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-hover-outline-color: var(--ct-color-dark-border)." },
      "title-color": { "$value": "{color.dark.heading}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-title-color: var(--ct-color-dark-heading)." },
      "title-hover-color": { "$value": "{color.dark.interaction.background}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-title-hover-color: var(--ct-color-dark-interaction-background)." },
      "title-icon-color": { "$value": "{color.dark.heading}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-title-icon-color: var(--ct-color-dark-heading)." },
      "filename-color": { "$value": "{color.dark.interaction.background}", "$type": "color", "description": "CivicTheme --ct-publication-card-dark-filename-color: var(--ct-color-dark-interaction-background)." }
    }
  }
}
