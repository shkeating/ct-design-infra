{
  "subject-card": {
    "border-radius": {
      "$value": "0.25rem",
      "$type": "dimension",
      "description": "CivicTheme --ct-subject-card-border-radius."
    },
    "image-height-mobile": {
      "$value": "10rem",
      "$type": "dimension",
      "description": "CivicTheme --ct-subject-card-image-height-mobile."
    },
    "image-width-mobile": {
      "$value": "auto",
      "$type": "other",
      "description": "CivicTheme --ct-subject-card-image-width-mobile."
    },
    "image-height-desktop": {
      "$value": "14rem",
      "$type": "dimension",
      "description": "CivicTheme --ct-subject-card-image-height-desktop."
    },
    "image-width-desktop": {
      "$value": "auto",
      "$type": "other",
      "description": "CivicTheme --ct-subject-card-image-width-desktop."
    },
    "light": {
      "background-color": { "$value": "{color.light.background-light}", "$type": "color", "description": "CivicTheme --ct-subject-card-light-background-color: var(--ct-color-light-background-light)." },
      "hover-outline-color": { "$value": "{color.light.border}", "$type": "color", "description": "CivicTheme --ct-subject-card-light-hover-outline-color: var(--ct-color-light-border)." },
      "title-color": { "$value": "{color.light.heading}", "$type": "color", "description": "CivicTheme --ct-subject-card-light-title-color: var(--ct-color-light-heading)." },
      "title-hover-color": { "$value": "{color.light.interaction.background}", "$type": "color", "description": "CivicTheme --ct-subject-card-light-title-hover-color: var(--ct-color-light-interaction-background)." },
      "image-opacity": { "$value": "30%", "$type": "dimension", "description": "CivicTheme --ct-subject-card-light-image-opacity." }
    },
    "dark": {
      "background-color": { "$value": "{color.dark.background}", "$type": "color", "description": "CivicTheme --ct-subject-card-dark-background-color: var(--ct-color-dark-background)." },
      "hover-outline-color": { "$value": "{color.dark.border}", "$type": "color", "description": "CivicTheme --ct-subject-card-dark-hover-outline-color: var(--ct-color-dark-border)." },
      "title-color": { "$value": "{color.dark.heading}", "$type": "color", "description": "CivicTheme --ct-subject-card-dark-title-color: var(--ct-color-dark-heading)." },
      "title-hover-color": { "$value": "{color.dark.interaction.background}", "$type": "color", "description": "CivicTheme --ct-subject-card-dark-title-hover-color: var(--ct-color-dark-interaction-background)." },
      "image-opacity": { "$value": "20%", "$type": "dimension", "description": "CivicTheme --ct-subject-card-dark-image-opacity." }
    }
  }
}
