{
  "color": {
    "brand": {
      "primary": {
        "$value": "#002a39",
        "$type": "color",
        "description": "CivicTheme Heading Color - Primary brand identity."
      },
      "secondary": {
        "$value": "#33444a",
        "$type": "color",
        "description": "CivicTheme Body Color - Neutral supporting brand color."
      },
      "accent": {
        "$value": "oklch(65% 0.15 20)",
        "$type": "color",
        "description": "CivicTheme Accent - Used for highlights and CTAs."
      }
    },
    "status": {
      "success": {
        "$value": "oklch(62% 0.17 145)",
        "$type": "color",
        "description": "Green status color for positive feedback and confirmations."
      },
      "warning": {
        "$value": "oklch(75% 0.15 75)",
        "$type": "color",
        "description": "Orange status color for cautionary information."
      },
      "error": {
        "$value": "oklch(55% 0.22 25)",
        "$type": "color",
        "description": "Red status color for critical errors and required actions."
      },
      "info": {
        "$value": "oklch(60% 0.15 250)",
        "$type": "color",
        "description": "Blue status color for general updates and information."
      }
    },
    "surface": {
      "light": { "$value": "#fdfdfd", "$type": "color" },
      "standard": { "$value": "#e6e9eb", "$type": "color" },
      "dark": { "$value": "#1a1c1d", "$type": "color" }
    }
  }
}
{
  "spacing": {
    "base": { "$value": "4px", "$type": "dimension" },
    "particle": {
      "1": { "$value": "{spacing.base}", "$type": "dimension" },
      "2": { "$value": "{spacing.base} * 2", "$type": "dimension" },
      "4": { "$value": "{spacing.base} * 4", "$type": "dimension" },
      "8": { "$value": "{spacing.base} * 8", "$type": "dimension" },
      "12": { "$value": "{spacing.base} * 12", "$type": "dimension" }
    },
    "layout": {
      "gutter": { "$value": "{spacing.particle.4}", "$type": "dimension" },
      "margin": { "$value": "{spacing.particle.8}", "$type": "dimension" }
    }
  }
}