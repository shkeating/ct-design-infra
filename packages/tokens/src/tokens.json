{
  "color": {
    "brand": {
      "primary": {
        "$value": "#002a39",
        "$type": "color",
        "description": "CivicTheme Heading Color. High-contrast teal for brand identity."
      },
      "secondary": {
        "$value": "#33444a",
        "$type": "color",
        "description": "CivicTheme Body Color. Neutral supporting brand color."
      },
      "accent": {
        "$value": "oklch(65% 0.15 20)",
        "$type": "color",
        "description": "Functional accent for call-to-actions and interactive highlights."
      }
    },
    "status": {
      "success": { "$value": "oklch(62% 0.17 145)", "$type": "color" },
      "warning": { "$value": "oklch(75% 0.15 75)", "$type": "color" },
      "error": { "$value": "oklch(55% 0.22 25)", "$type": "color" },
      "info": { "$value": "oklch(60% 0.15 250)", "$type": "color" }
    },
    "surface": {
      "light": { "$value": "#fdfdfd", "$type": "color" },
      "standard": { "$value": "#e6e9eb", "$type": "color" },
      "dark": { "$value": "#1a1c1d", "$type": "color" }
    },
    "interaction": {
      "light": {
        "background": { "$value": "#00698f", "$type": "color" },
        "text": { "$value": "#fafbfb", "$type": "color" },
        "hover-background": { "$value": "#003f56", "$type": "color" },
        "hover-text": { "$value": "#fafbfb", "$type": "color" },
        "focus": { "$value": "#8b5cd7", "$type": "color" }
      },
      "dark": {
        "background": { "$value": "#61daff", "$type": "color" },
        "text": { "$value": "#003a4f", "$type": "color" },
        "hover-background": { "$value": "#a0e9ff", "$type": "color" },
        "hover-text": { "$value": "#002937", "$type": "color" },
        "focus": { "$value": "#8b5cd7", "$type": "color" }
      }
    },
    "light": {
      "body": { "$value": "{color.brand.secondary}", "$type": "color", "description": "CivicTheme --ct-color-light-body." },
      "heading": { "$value": "{color.brand.primary}", "$type": "color", "description": "CivicTheme --ct-color-light-heading." },
      "background": { "$value": "{color.surface.standard}", "$type": "color", "description": "CivicTheme --ct-color-light-background." },
      "background-light": { "$value": "{color.surface.light}", "$type": "color", "description": "CivicTheme --ct-color-light-background-light." },
      "border-light": { "$value": "#adafb0", "$type": "color", "description": "CivicTheme --ct-color-light-border-light." },
      "highlight": { "$value": "#121313", "$type": "color", "description": "CivicTheme --ct-color-light-highlight." }
    },
    "dark": {
      "body": { "$value": "#e7f9ff", "$type": "color", "description": "CivicTheme --ct-color-dark-body." },
      "heading": { "$value": "#f7fdff", "$type": "color", "description": "CivicTheme --ct-color-dark-heading." },
      "background-dark": { "$value": "#002937", "$type": "color", "description": "CivicTheme --ct-color-dark-background-dark." },
      "background-light": { "$value": "#0d4458", "$type": "color", "description": "CivicTheme --ct-color-dark-background-light." },
      "border": { "$value": "#1a4e61", "$type": "color", "description": "CivicTheme --ct-color-dark-border." },
      "highlight": { "$value": "#00698f", "$type": "color", "description": "CivicTheme --ct-color-dark-highlight." }
    }
  },
  "spacing": {
    "base": { "$value": "8px", "$type": "dimension" },
    "particle": {
      "050": { "$value": "calc({spacing.base} * 0.5)", "$type": "dimension" },
      "100": { "$value": "{spacing.base}", "$type": "dimension" },
      "200": { "$value": "calc({spacing.base} * 2)", "$type": "dimension" },
      "300": { "$value": "calc({spacing.base} * 3)", "$type": "dimension" },
      "400": { "$value": "calc({spacing.base} * 4)", "$type": "dimension" },
      "600": { "$value": "calc({spacing.base} * 6)", "$type": "dimension" },
      "800": { "$value": "calc({spacing.base} * 8)", "$type": "dimension" },
      "1000": { "$value": "calc({spacing.base} * 10)", "$type": "dimension" }
    }
  },
  "breakpoint": {
    "xxs": { "$value": "0", "$type": "dimension" },
    "xs": { "$value": "368px", "$type": "dimension" },
    "s": { "$value": "576px", "$type": "dimension" },
    "m": { "$value": "768px", "$type": "dimension" },
    "l": { "$value": "992px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" },
    "xxl": { "$value": "1440px", "$type": "dimension" }
  },
  "typography": {
    "family": {
      "heading": { "$value": "Lexend, sans-serif", "$type": "fontFamily" },
      "body": { "$value": "Public Sans, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light": { "$value": "300", "$type": "fontWeight" },
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium": { "$value": "500", "$type": "fontWeight" },
      "bold": { "$value": "700", "$type": "fontWeight" }
    },
    "scale": {
      "base": { "$value": "16px", "$type": "dimension" },
      "ratio": { "$value": "1.25", "$type": "number" }
    },
    "label": {
      "large": {
        "font-size": { "$value": "1.125rem", "$type": "dimension" },
        "line-height": { "$value": "1.5rem", "$type": "dimension" },
        "font-weight": { "$value": "600", "$type": "fontWeight" },
        "letter-spacing": { "$value": "-0.1px", "$type": "dimension" }
      },
      "regular": {
        "font-size": { "$value": "1rem", "$type": "dimension" },
        "line-height": { "$value": "1.25rem", "$type": "dimension" },
        "font-weight": { "$value": "600", "$type": "fontWeight" },
        "letter-spacing": { "$value": "-0.1px", "$type": "dimension" }
      },
      "small": {
        "font-size": { "$value": "1rem", "$type": "dimension" },
        "line-height": { "$value": "1.25rem", "$type": "dimension" },
        "font-weight": { "$value": "400", "$type": "fontWeight" },
        "letter-spacing": { "$value": "-0.1px", "$type": "dimension" }
      }
    },
    "heading": {
      "6": {
        "font-size": { "$value": "1rem", "$type": "dimension" },
        "line-height": { "$value": "1.625rem", "$type": "dimension" },
        "font-weight": { "$value": "{typography.weight.bold}", "$type": "fontWeight" },
        "letter-spacing": { "$value": "0", "$type": "dimension" }
      }
    }
  },
  "button": {
    "border-radius": { "$value": "0.25rem", "$type": "dimension" },
    "border-width": { "$value": "0.125rem", "$type": "dimension" },
    "outline-offset": { "$value": "0.125rem", "$type": "dimension" },
    "outline-width": { "$value": "0.1875rem", "$type": "dimension" },
    "animation-duration": { "$value": "0.25s", "$type": "duration" }
  },
  "stripe": {
    "size": { "$value": "0.375rem", "$type": "dimension", "description": "CivicTheme --ct-stripe-size, the decorative accent-bar width used by accordion/card panels." }
  },
  "accordion": {
    "button-border-radius": { "$value": "0.25rem", "$type": "dimension" },
    "header-border-radius": { "$value": "0.25rem", "$type": "dimension" },
    "item-border-radius": { "$value": "0.25rem", "$type": "dimension" },
    "space-horizontal": { "$value": "1.5rem", "$type": "dimension" },
    "space-horizontal-desktop": { "$value": "3.5rem", "$type": "dimension" },
    "outline-offset": { "$value": "0", "$type": "dimension" },
    "outline-width": { "$value": "0.1875rem", "$type": "dimension" }
  }
}
