{
  "color": {
    "brand": {
      "primary": {
        "$value": "#002a39",
        "$type": "color",
        "description": "CivicTheme Heading Color - Dark teal base."
      },
      "secondary": {
        "$value": "#33444a",
        "$type": "color",
        "description": "CivicTheme Body Color - Neutral grey-blue."
      }
    },
    "surface": {
      "light": { "$value": "#fdfdfd", "$type": "color" },
      "standard": { "$value": "#e6e9eb", "$type": "color" }
    }
  },
  "spacing": {
    "base": { "$value": "4px", "$type": "dimension" },
    "scale": {
      "xs": { "$value": "{spacing.base} * 2", "$type": "dimension" },
      "sm": { "$value": "{spacing.base} * 4", "$type": "dimension" },
      "md": { "$value": "{spacing.base} * 8", "$type": "dimension" },
      "lg": { "$value": "{spacing.base} * 12", "$type": "dimension" }
    }
  }
}
